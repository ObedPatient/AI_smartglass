# .env.example - SAFE TO COMMIT TO GIT
# Copy this file to .env and fill in your actual values

SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database URL (leave empty for SQLite, set for PostgreSQL)
# Local: sqlite:///db.sqlite3
# Production: postgresql://user:pass@host:port/dbname
DATABASE_URL=

# Free AI Vision Agent keys — no credit card required for either
# Get Gemini key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Get Mistral key: https://console.mistral.ai -> API Keys  
MISTRAL_API_KEY=your-mistral-api-key-here